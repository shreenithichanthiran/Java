package Basic;
import java.util.Scanner;
public class Q5 {
	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		int totalbill = s.nextInt();
		int service = s.nextInt();
		int gst = s.nextInt();
		int numberofpepole = s.nextInt();
		int sum = totalbill*service/100;
		int cal= totalbill*gst/100;
		int perperson =totalbill+sum+cal;
		int amount = perperson/numberofpepole;
		System.out.println(amount);
	}
}
